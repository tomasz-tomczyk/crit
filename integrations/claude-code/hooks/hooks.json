{
  "description": "Intercept plan mode exit for inline review via crit",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "crit plan-hook",
            "timeout": 345600
          }
        ]
      }
    ]
  }
}
